{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "graph_entry_type", "product", "gotcha_id", "severity",
    "the_problem", "how_it_manifests", "when_to_surface_this",
    "mitigation_options"
  ],
  "properties": {
    "graph_entry_type": { "const": "gotcha" },
    "product": { "type": "string" },
    "gotcha_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["high", "medium", "low"] },
    "the_problem": { "type": "string" },
    "how_it_manifests": { "type": "array" },
    "when_to_surface_this": { "type": "array" },
    "mitigation_options": { "type": "array" }
  }
}
